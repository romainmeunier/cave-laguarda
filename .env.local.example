# Copie ce fichier en .env.local et remplis les valeurs depuis Supabase :
#   Project Settings → API → Project URL et Publishable key.
# Pas commité (.env.local est dans .gitignore).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
